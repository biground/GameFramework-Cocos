{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./assets/scripts",
    "baseUrl": ".",
    "paths": {
      "@framework/*": ["assets/scripts/framework/*"],
      "@runtime/*": ["assets/scripts/runtime/*"],
      "@game/*": ["assets/scripts/game/*"],
      "@utils/*": ["assets/scripts/utils/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["assets/scripts/**/*.ts", "tests/**/*.ts", "tools/**/*.ts"],
  "exclude": ["node_modules", "dist", "build", "temp", "library"]
}
